# Default values for Symfony. Real secrets come from environment variables in production.
# https://symfony.com/doc/current/configuration.html#configuration-based-on-environment-variables

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-in-production
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

MODULE_SIGNATURE_WINDOW_SECONDS=300
HEARTBEAT_WARNING_SECONDS=900
HEARTBEAT_CRITICAL_SECONDS=1800
MAILER_DSN=null://null
MAILER_FROM=monitoring@localhost
TELEGRAM_PROXY_URL=
CRITICAL_TELEGRAM_REMINDER_SECONDS=3600
INTERNAL_API_TOKEN=dev-internal-token
PROBE_ID=local-1
PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
TELEGRAM_BOT_TOKEN=

###> demo account (dev only; overridden in production) ###
DEMO_USER_EMAIL=demo@monitoring.local
DEMO_USER_PASSWORD=Demo123456
DEMO_USER_NAME="Demo User"
DEMO_ORGANIZATION_NAME="Demo Organization"
###< demo account ###

###> platform admin ###
PLATFORM_ADMIN_EMAIL=admin@monitoring.local
PLATFORM_ADMIN_PASSWORD=Admin123456
PLATFORM_ADMIN_NAME="Platform Admin"
###< platform admin ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://monitoring:monitoring@postgres:5432/monitoring?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
###< symfony/messenger ###
