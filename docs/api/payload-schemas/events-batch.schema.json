{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monitoring.example.com/schemas/events-batch.schema.json",
  "title": "EventsBatchPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["batchId", "events"],
  "properties": {
    "batchId": {
      "type": "string",
      "format": "uuid"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eventId", "type", "occurredAt", "payload"],
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
            "examples": ["backup.last_success", "collector.error"]
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "maxProperties": 50
          },
          "severityHint": {
            "type": "string",
            "enum": ["ok", "info", "warning", "critical", "unknown"]
          }
        }
      }
    }
  }
}
