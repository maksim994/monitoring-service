# Скопируйте переменные в Coolify -> Environment Variables.
# Не коммитьте реальные секреты в Git.

# --- Обязательные ---
APP_SECRET=replace-with-long-random-string
POSTGRES_PASSWORD=replace-with-strong-db-password
INTERNAL_API_TOKEN=replace-with-long-random-token
FRONTEND_URL=https://monitoring.example.com

# --- База данных (внутри compose) ---
POSTGRES_DB=monitoring
POSTGRES_USER=monitoring

# --- CORS (если кабинет и API на одном домене через nginx — можно оставить широким) ---
CORS_ALLOW_ORIGIN='^https?://.*$'

# --- Почта (SMTP, например Mail.ru) ---
# Mail.ru: в DSN только пароль приложения, не пароль входа в web-почту
# https://help.mail.ru/mail/security/protection/external
# MAILER_DSN=smtps://user%40domain.ru:APP_PASSWORD@smtp.mail.ru:465
# MAILER_FROM=mail@mv-deploy.ru

# --- Telegram (опционально) ---
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Прокси для api.telegram.org (если сервер в РФ без прямого доступа):
# TELEGRAM_PROXY_URL=http://user:pass@proxy-host:3128
# CRITICAL_TELEGRAM_REMINDER_SECONDS=3600

# --- Platform admin (создаётся вручную после деплоя) ---
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-with-strong-password
PLATFORM_ADMIN_NAME=Platform Admin

# --- Probe ---
PROBE_ID=prod-1

# --- Heartbeat thresholds (секунды) ---
HEARTBEAT_WARNING_SECONDS=900
HEARTBEAT_CRITICAL_SECONDS=1800
MODULE_SIGNATURE_WINDOW_SECONDS=300

# --- Symfony за reverse proxy Coolify/Traefik ---
SYMFONY_TRUSTED_PROXIES=0.0.0.0/0
SYMFONY_TRUSTED_HEADERS=x-forwarded-for,x-forwarded-proto,x-forwarded-host,x-forwarded-port
